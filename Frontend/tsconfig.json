{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "rootDir": "./src",
    "paths": { "@/*": ["./src/*"] },
    "outDir": "./dist"
  },
  "include": ["src"]
}
